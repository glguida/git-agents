@dataclass
class Config:
    root: Path
    host: str
    port: int
    registry: bool = False
    registry_dir: Path = DEFAULT_REGISTRY_DIR.expanduser()


class GitAgentsServer(ThreadingHTTPServer):
    allow_reuse_address = True


def bind_server(config: Config):
    attempts = 100 if config.port else 1
    last_error = None
    for offset in range(attempts):
        port = config.port + offset if config.port else 0
        try:
            server = GitAgentsServer((config.host, port), ViewerHandler)
            if offset:
                print(f"GitAgents port {config.port} was busy; using {port}.", file=sys.stderr)
            return server
        except OSError as exc:
            last_error = exc
            if exc.errno == errno.EADDRINUSE and offset + 1 < attempts:
                continue
            break

    exc = last_error
    url = f"http://{config.host}:{config.port}"
    reason = exc.strerror if exc and exc.strerror else str(exc)
    print(f"error: cannot start GitAgents web interface at {url}: {reason}", file=sys.stderr)
    if exc and exc.errno == errno.EADDRINUSE:
        end_port = config.port + attempts - 1
        print(f"hint: tried ports {config.port}-{end_port}; stop the listener or pass --port <port>.", file=sys.stderr)
    elif exc and exc.errno in (errno.EACCES, errno.EPERM):
        print("hint: permission denied while binding; use the default 127.0.0.1 host or choose another port.", file=sys.stderr)
    elif exc and exc.errno == errno.EADDRNOTAVAIL:
        print("hint: the requested host is not available on this machine; try --host 127.0.0.1.", file=sys.stderr)
    return None


def server_url(server, config: Config):
    host = config.host
    if host in ("", "0.0.0.0", "::"):
        host = "127.0.0.1"
    if ":" in host and not host.startswith("["):
        host = f"[{host}]"
    return f"http://{host}:{server.server_address[1]}"


def utc_now():
    return datetime.now(timezone.utc).isoformat().replace("+00:00", "Z")


def iso_from_stat(path: Path):
    try:
        return datetime.fromtimestamp(path.stat().st_mtime, timezone.utc).isoformat().replace("+00:00", "Z")
    except OSError:
        return None


def read_text(path: Path, fallback="", max_bytes=256 * 1024, tail=False):
    try:
        size = path.stat().st_size
        with path.open("rb") as stream:
            if size <= max_bytes:
                return stream.read().decode("utf-8", "replace")
            if tail:
                stream.seek(max(0, size - max_bytes))
                return "\n[... earlier content truncated ...]\n" + stream.read(max_bytes).decode("utf-8", "replace")
            return stream.read(max_bytes).decode("utf-8", "replace") + "\n[... content truncated ...]\n"
    except OSError:
        return fallback


def list_dirs(path: Path, include_hidden=False):
    try:
        return sorted(
            item.name
            for item in path.iterdir()
            if item.is_dir() and (include_hidden or not item.name.startswith("."))
        )
    except OSError:
        return []


def pid_is_running(pid):
    if not pid:
        return False
    try:
        os.kill(int(pid), 0)
        return True
    except (OSError, ValueError):
        return False


def read_pid(path: Path):
    try:
        text = path.read_text(encoding="utf-8").strip()
        if not text:
            return None
        return int(text)
    except (OSError, ValueError):
        return None


def registry_entries(config: Config):
    if not config.registry:
        return [
            {
                "id": "local",
                "repoRoot": "",
                "gitAgentsRoot": str(config.root.parent if config.root.name == "state" else config.root),
                "stateRoot": str(config.root),
                "supervisorPid": None,
                "running": True,
                "valid": True,
                "title": config.root.parent.name if config.root.name == "state" else config.root.name,
                "updatedAt": None,
            }
        ]

    instances_dir = config.registry_dir / "instances"
    entries = []
    try:
        paths = sorted(instances_dir.iterdir(), key=lambda item: item.name)
    except OSError:
        paths = []

    for path in paths:
        if path.name.endswith(".json"):
            continue
        try:
            git_agents_root = path.resolve(strict=True)
        except OSError:
            git_agents_root = path.resolve(strict=False)
        state_root = git_agents_root / "state"
        repo_root_text = read_text(state_root / "repo-root", max_bytes=4096).strip()
        repo_root = Path(repo_root_text).expanduser() if repo_root_text else git_agents_root.parent
        supervisor_pid = read_pid(state_root / "runs" / "supervisor.pid")
        valid = state_root.is_dir() and (state_root / "jobs").is_dir() and (state_root / "agents").is_dir()
        running = pid_is_running(supervisor_pid)
        updated_at = (
            iso_from_stat(state_root / "runs" / "supervisor-heartbeat")
            or iso_from_stat(state_root / "runs" / "supervisor.pid")
            or iso_from_stat(path)
        )
        entries.append(
            {
                "id": path.name,
                "repoRoot": str(repo_root) if str(repo_root) else "",
                "gitAgentsRoot": str(git_agents_root),
                "stateRoot": str(state_root) if str(state_root) else "",
                "supervisorPid": supervisor_pid,
                "running": running,
                "valid": valid,
                "title": repo_root.name if str(repo_root) else path.name,
                "updatedAt": updated_at,
            }
        )
    return entries


def default_registry_root(config: Config):
    entries = registry_entries(config)
    for entry in entries:
        if entry["running"] and entry["valid"]:
            return entry["stateRoot"]
    for entry in entries:
        if entry["valid"]:
            return entry["stateRoot"]
    return str(config.root)


def requested_root(config: Config, query):
    root_value = query.get("root", [""])[0]
    if not root_value and config.registry:
        root_value = default_registry_root(config)
    if not root_value:
        root_value = str(config.root)
    return Path(root_value).expanduser()


def first_markdown_title(markdown, fallback):
    match = re.search(r"^#\s+(.+)$", markdown, re.MULTILINE)
    return match.group(1).strip() if match else titleize(fallback)


def titleize(value):
    return re.sub(r"\b\w", lambda match: match.group(0).upper(), re.sub(r"[-_]+", " ", str(value or "")))


def markdown_section(markdown, heading):
    pattern = re.compile(rf"^##\s+{re.escape(heading)}\s*$([\s\S]*?)(?=^##\s+|\Z)", re.IGNORECASE | re.MULTILINE)
    match = pattern.search(markdown)
    return re.sub(r"\n{3,}", "\n\n", match.group(1).strip()) if match else ""


def first_paragraph(markdown):
    body = re.sub(r"^#.+$", "", markdown, count=1, flags=re.MULTILINE)
    for block in re.split(r"\n{2,}", body):
        block = block.strip()
        if block and not block.startswith("##"):
            return block
    return ""


def short_excerpt(value, length=280):
    clean = re.sub(r"`([^`]+)`", r"\1", str(value or ""))
    clean = re.sub(r"\s+", " ", clean).strip()
    return clean[: length - 1] + "..." if len(clean) > length else clean


def parse_events(markdown):
    events = []
    current = None
    for line in markdown.splitlines():
        match = re.match(r"^##\s+([0-9T:.-]+Z)\s+-\s+(.+)$", line)
        if match:
            if current:
                current["body"] = current["body"].strip()
                events.append(current)
            current = {"timestamp": match.group(1), "title": match.group(2).strip(), "body": ""}
        elif current:
            current["body"] += line + "\n"
    if current:
        current["body"] = current["body"].strip()
        events.append(current)
    return events


def date_value(value):
    if not value:
        return 0
    try:
        return datetime.fromisoformat(value.replace("Z", "+00:00")).timestamp()
    except ValueError:
        return 0


def duration_ms(start, end):
    a = date_value(start)
    b = date_value(end)
    return int((b - a) * 1000) if a and b and b >= a else None


def infer_stage(job_id, role):
    lower = job_id.lower()
    if re.search(r"(^|-)notify(-\d+)?$", job_id):
        return "notify"
    if re.search(r"(^|-)(commit|clean-commit)(-\d+)?$", job_id) or re.search(r"(^|-)integrate(?:-[a-z0-9_-]+)?(-\d+)?$", job_id):
        return "integrate"
    if re.search(r"(^|-)review(-\d+)?$", job_id):
        return "review"
    if re.search(r"(^|-)(impl|implementation|fix|build)(-\d+)?$", job_id):
        return "build"
    if re.search(r"(^|-)plan(-\d+)?$", job_id):
        return "plan"
    if re.search(r"(^|-)doc", lower):
        return "docs"
    if re.search(r"(^|-)rebase($|-)", lower):
        return "rebase"
    return ROLE_STAGE.get(role.lower(), "other")


def status_rank(status):
    return {"failed": 0, "running": 1, "claimed": 2, "pending": 3, "done": 4, "unknown": 5}.get(status, 6)


def read_tasks(root: Path):
    tasks = []
    for task_id in list_dirs(root / "tasks"):
        task_dir = root / "tasks" / task_id
        state = read_text(task_dir / "state", "open", 1024).strip() or "open"
        spec = read_text(task_dir / "spec.md", max_bytes=160 * 1024)
        log = read_text(task_dir / "log.md", max_bytes=512 * 1024)
        result_path = task_dir / "result.md"
        result = read_text(result_path, max_bytes=160 * 1024)
        events = parse_events(log)
        last = events[-1] if events else None
        objective = markdown_section(spec, "Objective") or first_paragraph(spec)
        tasks.append(
            {
                "id": task_id,
                "title": first_markdown_title(spec, task_id),
                "state": state,
                "objective": short_excerpt(objective, 420),
                "specPreview": short_excerpt(spec, 520),
                "resultPreview": short_excerpt(result, 520),
                "hasResult": result_path.exists(),
                "eventCount": len(events),
                "events": events,
                "createdAt": (events[0]["timestamp"] if events else iso_from_stat(task_dir)),
                "updatedAt": (last["timestamp"] if last else iso_from_stat(task_dir)),
            }
        )
    return tasks


def read_jobs(root: Path):
    jobs = []
    for job_id in list_dirs(root / "jobs"):
        job_dir = root / "jobs" / job_id
        status = read_text(job_dir / "status", "unknown", 1024).strip() or "unknown"
        task_id = read_text(job_dir / "task-id", max_bytes=1024).strip()
        role = read_text(job_dir / "role", max_bytes=1024).strip()
        agent_id = read_text(job_dir / "agent-id", max_bytes=1024).strip()
        spec = read_text(job_dir / "spec.md", max_bytes=160 * 1024)
        log = read_text(job_dir / "log.md", max_bytes=512 * 1024)
        events = parse_events(log)
        first = events[0] if events else None
        last = events[-1] if events else None
        last_text = f"{last.get('title', '') if last else ''} {last.get('body', '') if last else ''}"
        try:
            log_size = (job_dir / "log.md").stat().st_size
        except OSError:
            log_size = 0
        jobs.append(
            {
                "id": job_id,
                "title": titleize(job_id),
                "status": status,
                "taskId": task_id,
                "role": role,
                "agentId": agent_id,
                "stage": infer_stage(job_id, role),
                "eventCount": len(events),
                "events": events,
                "firstEventAt": first["timestamp"] if first else None,
                "updatedAt": last["timestamp"] if last else iso_from_stat(job_dir),
                "durationMs": duration_ms(first["timestamp"] if first else None, last["timestamp"] if last else None),
                "specPreview": short_excerpt(spec, 420),
                "latestSummary": short_excerpt((last or {}).get("body") or (last or {}).get("title") or spec, 360),
                "attention": status == "failed" or bool(re.search(r"blocked|error|failed|superseded", last_text, re.IGNORECASE)),
                "logSize": log_size,
            }
        )
    return sorted(jobs, key=lambda job: (status_rank(job["status"]), -date_value(job["updatedAt"]), job["id"]))


def list_agent_sessions(agent_dir: Path):
    session_dir = agent_dir / "pi-session"
    try:
        return [item.name for item in session_dir.iterdir() if item.is_file() and item.name.endswith(".jsonl")]
    except OSError:
        return []


def read_agents(root: Path, jobs_by_agent):
    agents = []
    team_runs = root / "agents" / ".team-runs"
    for agent_id in list_dirs(root / "agents"):
        agent_dir = root / "agents" / agent_id
        jobs = jobs_by_agent.get(agent_id, [])
        active_jobs = [job for job in jobs if job["status"] in {"claimed", "running"}]
        interactive = (agent_dir / "interactive").is_file()
        input_fifo = agent_dir / "input.fifo"
        input_ready = is_fifo_writable(input_fifo)
        agents.append(
            {
                "id": agent_id,
                "name": read_text(agent_dir / "name", agent_id, 2048).strip() or agent_id,
                "role": read_text(agent_dir / "role", max_bytes=2048).strip(),
                "engine": read_text(agent_dir / "engine", max_bytes=2048).strip(),
                "createdAt": read_text(agent_dir / "created_at", max_bytes=2048).strip(),
                "lastStartedAt": read_text(agent_dir / "last_started_at", max_bytes=2048).strip(),
                "currentJob": read_text(agent_dir / "current-job", max_bytes=2048).strip(),
                "active": bool(active_jobs) or (interactive and input_ready),
                "activeJobIds": [job["id"] for job in active_jobs],
                "jobCount": len(jobs),
                "doneJobs": len([job for job in jobs if job["status"] == "done"]),
                "failedJobs": len([job for job in jobs if job["status"] == "failed"]),
                "transcriptSize": file_size(agent_dir / "transcript.log"),
                "errorSize": file_size(agent_dir / "error.log"),
                "sessionCount": len(list_agent_sessions(agent_dir)),
                "promptPreview": short_excerpt(read_text(agent_dir / "prompt.md", max_bytes=80 * 1024), 420),
                "runnerStatus": read_text(team_runs / f"{agent_id}.last-status", max_bytes=2048).strip(),
                "runnerExit": read_text(team_runs / f"{agent_id}.last-exit", max_bytes=2048).strip(),
                "interactive": interactive,
                "inputReady": input_ready,
                "busy": input_ready and read_text(agent_dir / "busy", max_bytes=64).strip() == "1",
            }
        )
    return sorted(agents, key=lambda agent: (agent["role"], agent["id"]))


def file_size(path: Path):
    try:
        return path.stat().st_size
    except OSError:
        return 0


def is_fifo(path: Path):
    try:
        return stat.S_ISFIFO(path.stat().st_mode)
    except OSError:
        return False


def is_fifo_writable(path: Path):
    if not is_fifo(path):
        return False
    try:
        fd = os.open(path, os.O_WRONLY | os.O_NONBLOCK)
    except OSError:
        return False
    else:
        os.close(fd)
        return True


def enrich_tasks(tasks, jobs):
    by_task = {}
    for job in jobs:
        by_task.setdefault(job["taskId"], []).append(job)

    for task in tasks:
        task_jobs = sorted(
            by_task.get(task["id"], []),
            key=lambda job: (date_value(job.get("firstEventAt") or job.get("updatedAt")), job["id"]),
        )
        cycle_start = task_reopen_timestamp(task)
        flow_jobs = [job for job in task_jobs if not cycle_start or date_value(job.get("updatedAt")) >= cycle_start]
        done = len([job for job in task_jobs if job["status"] == "done"])
        failed = len([job for job in flow_jobs if job["status"] == "failed"])
        running = len([job for job in flow_jobs if job["status"] in {"running", "claimed"}])
        pending = len([job for job in flow_jobs if job["status"] == "pending"])
        attention = failed > 0 or any(job["attention"] for job in flow_jobs)
        task["jobs"] = [job["id"] for job in task_jobs]
        task["jobCount"] = len(task_jobs)
        task["doneJobs"] = done
        task["failedJobs"] = failed
        task["runningJobs"] = running
        task["pendingJobs"] = pending
        task["roles"] = sorted({job["role"] for job in task_jobs if job["role"]})
        task["agents"] = sorted({job["agentId"] for job in task_jobs if job["agentId"]})
        task["flowState"] = infer_task_flow_state(task, flow_jobs, attention)
        task["progress"] = 100 if task["flowState"] == "closed" else round((done / len(task_jobs)) * 100) if task_jobs else 0
        task["latestJob"] = max(task_jobs, key=lambda job: date_value(job.get("updatedAt")), default={}).get("id", "")
        timestamps = [task.get("updatedAt")] + [job.get("updatedAt") for job in task_jobs]
        task["updatedAt"] = max((value for value in timestamps if value), key=date_value, default=task.get("updatedAt"))
    return sorted(tasks, key=lambda task: (-date_value(task.get("updatedAt")), task["id"]))


def infer_task_flow_state(task, jobs, attention):
    if is_task_closed(task):
        return "closed"
    if attention:
        return "blocked"
    if any(job["status"] in {"running", "claimed"} for job in jobs):
        return "active"
    pending = [job for job in jobs if job["status"] == "pending"]
    if any(job["stage"] == "integrate" for job in pending):
        return "integrate"
    if any(job["stage"] == "review" for job in pending):
        return "review"
    if any(job["stage"] in {"build", "rebase", "docs"} for job in pending):
        return "active"
    if any(job["stage"] == "plan" for job in pending):
        return "planning"
    if jobs:
        return "integrate"
    return "intake"


def is_task_closed(task):
    state = task.get("state", "open")
    if state and state != "open":
        return True

    latest_reopen = task_reopen_timestamp(task)
    latest_result = task_result_timestamp(task)
    if latest_reopen and latest_reopen >= latest_result:
        return False

    return task["hasResult"] or bool(latest_result)


def task_result_timestamp(task):
    return max(
        (date_value(event["timestamp"]) for event in task["events"] if re.search(r"result recorded", event["title"], re.IGNORECASE)),
        default=0,
    )


def task_reopen_timestamp(task):
    latest_result = task_result_timestamp(task)
    latest_reopen = max(
        (
            date_value(event["timestamp"])
            for event in task["events"]
            if re.search(r"\bstate:\s*open\b", f"{event['title']} {event['body']}", re.IGNORECASE)
        ),
        default=0,
    )
    return latest_reopen if latest_reopen and latest_reopen >= latest_result else 0


def build_activity(tasks, jobs):
    activity = []
    for task in tasks:
        for index, event in enumerate(task["events"]):
            activity.append(
                {
                    "id": f"task:{task['id']}:{index}",
                    "type": "task",
                    "itemId": task["id"],
                    "taskId": task["id"],
                    "timestamp": event["timestamp"],
                    "title": event["title"],
                    "body": short_excerpt(event["body"], 360),
                    "status": task["flowState"],
                }
            )
    for job in jobs:
        for index, event in enumerate(job["events"]):
            activity.append(
                {
                    "id": f"job:{job['id']}:{index}",
                    "type": "job",
                    "itemId": job["id"],
                    "taskId": job["taskId"],
                    "timestamp": event["timestamp"],
                    "title": event["title"],
                    "body": short_excerpt(event["body"], 360),
                    "status": job["status"],
                    "role": job["role"],
                    "agentId": job["agentId"],
                }
            )
    return sorted([event for event in activity if event["timestamp"]], key=lambda event: -date_value(event["timestamp"]))[:160]


def build_metrics(tasks, jobs, agents):
    return {
        "tasksTotal": len(tasks),
        "tasksByFlow": count_by(tasks, "flowState"),
        "jobsTotal": len(jobs),
        "jobsByStatus": count_by(jobs, "status"),
        "agentsTotal": len(agents),
        "activeAgents": len([agent for agent in agents if agent["active"]]),
        "failedJobs": len([job for job in jobs if job["status"] == "failed"]),
        "attentionTasks": len([task for task in tasks if task["flowState"] == "blocked"]),
    }


def count_by(items, field):
    result = {}
    for item in items:
        key = item.get(field) or "unknown"
        result[key] = result.get(key, 0) + 1
    return result


def build_snapshot(root: Path):
    root = root.resolve()
    missing = [name for name in ("tasks", "jobs", "agents") if not (root / name).is_dir()]
    if missing:
        raise ValueError(f"GitAgents root is missing {', '.join(missing)}: {root}")

    tasks_raw = read_tasks(root)
    jobs = read_jobs(root)
    jobs_by_agent = {}
    for job in jobs:
        if job["agentId"]:
            jobs_by_agent.setdefault(job["agentId"], []).append(job)
    agents = read_agents(root, jobs_by_agent)
    tasks = enrich_tasks(tasks_raw, jobs)
    return {
        "root": str(root),
        "generatedAt": utc_now(),
        "tasks": tasks,
        "jobs": jobs,
        "agents": agents,
        "activity": build_activity(tasks, jobs),
        "metrics": build_metrics(tasks, jobs, agents),
    }


class ViewerHandler(BaseHTTPRequestHandler):
    config: Config

    def log_message(self, fmt, *args):
        sys.stderr.write("%s - %s\n" % (self.address_string(), fmt % args))

    def do_GET(self):
        parsed = urlparse(self.path)
        if parsed.path.startswith("/api/"):
            self.handle_api(parsed)
        else:
            self.serve_static(parsed.path)

    def do_POST(self):
        parsed = urlparse(self.path)
        if parsed.path.startswith("/api/"):
            self.handle_api_post(parsed)
        else:
            self.send_json(404, {"error": "unknown route"})

    def handle_api(self, parsed):
        query = parse_qs(parsed.query)
        root = requested_root(self.config, query)
        try:
            if parsed.path == "/api/instances":
                instances = registry_entries(self.config)
                self.send_json(
                    200,
                    {
                        "registry": self.config.registry,
                        "registryRoot": str(self.config.registry_dir),
                        "defaultRoot": default_registry_root(self.config),
                        "instances": instances,
                    },
                )
            elif parsed.path == "/api/snapshot":
                self.send_json(200, build_snapshot(root))
            elif parsed.path == "/api/file":
                self.handle_file(root, query)
            else:
                self.send_json(404, {"error": "unknown api route"})
        except Exception as exc:
            self.send_json(400, {"error": str(exc)})

    def handle_api_post(self, parsed):
        query = parse_qs(parsed.query)
        root = requested_root(self.config, query)
        try:
            if parsed.path == "/api/agent-input":
                self.handle_agent_input(root, query)
            else:
                self.send_json(404, {"error": "unknown api route"})
        except Exception as exc:
            self.send_json(400, {"error": str(exc)})

    def handle_file(self, root: Path, query):
        item_type = query.get("type", [""])[0]
        item_id = query.get("id", [""])[0]
        filename = query.get("file", [""])[0]
        if item_type not in TYPE_DIR:
            raise ValueError("invalid type")
        if not VALID_ID.match(item_id):
            raise ValueError("invalid id")
        if filename not in ALLOWED_FILES[item_type]:
            raise ValueError("invalid file")

        max_bytes = min(int(query.get("maxBytes", ["524288"])[0] or 524288), 2 * 1024 * 1024)
        tail = query.get("tail", ["0"])[0] == "1"
        path = root.resolve() / TYPE_DIR[item_type] / item_id / filename
        if not path.is_file():
            self.send_json(404, {"error": "file not found"})
            return

        size = path.stat().st_size
        self.send_json(
            200,
            {
                "type": item_type,
                "id": item_id,
                "file": filename,
                "path": str(path),
                "size": size,
                "truncated": size > max_bytes,
                "text": read_text(path, max_bytes=max_bytes, tail=tail),
            },
        )

    def handle_agent_input(self, root: Path, query):
        agent_id = query.get("id", [""])[0]
        if not VALID_ID.match(agent_id):
            raise ValueError("invalid agent id")

        length = min(int(self.headers.get("Content-Length", "0") or "0"), 64 * 1024)
        payload = json.loads(self.rfile.read(length).decode("utf-8") or "{}")
        message = str(payload.get("message") or "").strip()
        mode = str(payload.get("mode") or "follow_up")
        if not message:
            raise ValueError("message is required")
        if mode not in {"follow_up", "steer", "prompt"}:
            raise ValueError("invalid mode")

        agent_dir = root.resolve() / "agents" / agent_id
        if not (agent_dir / "interactive").is_file():
            self.send_json(409, {"error": "agent is not interactive"})
            return
        input_fifo = agent_dir / "input.fifo"
        if not is_fifo(input_fifo):
            self.send_json(409, {"error": "interactive input is not ready"})
            return

        line = json.dumps({"message": message, "mode": mode}) + "\n"
        try:
            fd = os.open(input_fifo, os.O_WRONLY | os.O_NONBLOCK)
        except OSError as exc:
            if exc.errno == errno.ENXIO:
                self.send_json(409, {"error": "interactive agent is not listening; restart GitAgents or wait for the console to finish starting"})
                return
            self.send_json(409, {"error": f"interactive input is not available: {exc.strerror}"})
            return
        try:
            os.write(fd, line.encode("utf-8"))
        finally:
            os.close(fd)
        self.send_json(200, {"ok": True})

    def serve_static(self, raw_path):
        relative = unquote(raw_path.lstrip("/")) or "index.html"
        if relative == "":
            relative = "index.html"
        requested = (PUBLIC_DIR / relative).resolve()
        try:
            requested.relative_to(PUBLIC_DIR.resolve())
        except ValueError:
            self.send_error(403)
            return
        if not requested.is_file():
            requested = PUBLIC_DIR / "index.html"
        content_type = mimetypes.guess_type(str(requested))[0] or "application/octet-stream"
        payload = requested.read_bytes()
        self.send_response(200)
        self.send_header("Content-Type", content_type)
        self.send_header("Content-Length", str(len(payload)))
        self.send_header("Cache-Control", "no-store")
        self.end_headers()
        self.wfile.write(payload)

    def send_json(self, status, payload):
        body = json.dumps(payload).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Cache-Control", "no-store")
        self.end_headers()
        self.wfile.write(body)


def start_console(root: Path, model: str | None, verbose: bool):
    git_agents_root = root.parent if root.name == "state" else root
    console = git_agents_root / "tools" / "agent-pi-interactive"
    if not console.is_file():
        raise ValueError(f"GitAgents console runner not found: {console}")

    command = [str(console), "--pi", "--console"]
    if not verbose:
        command.append("--headless")
    if model:
        command.extend(["--model", model])

    env = os.environ.copy()
    env["GIT_AGENTS_ROOT"] = str(git_agents_root)
    env["GIT_AGENTS_STATE_DIR"] = str(root)
    proc = subprocess.Popen(command, cwd=git_agents_root, start_new_session=True, env=env)
    time.sleep(0.2)
    rc = proc.poll()
    if rc is not None:
        raise RuntimeError(f"GitAgents console exited early with status {rc}")
    return proc


def stop_team(proc):
    if proc is None:
        return
    # The leader may already be gone while child agents remain in its process group.
    running = proc.poll() is None
    try:
        os.killpg(proc.pid, signal.SIGTERM)
    except ProcessLookupError:
        return
    if not running:
        return
    try:
        proc.wait(timeout=5)
    except subprocess.TimeoutExpired:
        os.killpg(proc.pid, signal.SIGKILL)
        proc.wait(timeout=5)


class ProcessSupervisor:
    def __init__(
        self,
        label,
        starter,
        check_interval=PROCESS_CHECK_INTERVAL,
        restart_delay=PROCESS_RESTART_DELAY,
    ):
        self.label = label
        self.starter = starter
        self.check_interval = check_interval
        self.restart_delay = restart_delay
        self.stop_event = threading.Event()
        self.lock = threading.Lock()
        self.proc = None
        self.thread = None

    def start(self):
        proc = self.starter()
        with self.lock:
            self.proc = proc
        print(f"GitAgents {self.label} started pid={proc.pid}")
        self.thread = threading.Thread(
            target=self.watch,
            name=f"git_agents-{self.label}-supervisor",
            daemon=True,
        )
        self.thread.start()

    def current_proc(self):
        with self.lock:
            return self.proc

    def set_proc(self, proc):
        with self.lock:
            self.proc = proc

    def watch(self):
        while not self.stop_event.wait(self.check_interval):
            proc = self.current_proc()
            if proc is None:
                continue
            rc = proc.poll()
            if rc is None:
                continue

            self.set_proc(None)
            if self.stop_event.is_set():
                return
            print(f"GitAgents {self.label} exited with status {rc}; restarting.", file=sys.stderr)
            stop_team(proc)
            self.restart()

    def restart(self):
        while not self.stop_event.is_set():
            try:
                proc = self.starter()
            except (OSError, RuntimeError, ValueError) as exc:
                print(f"error: failed to restart GitAgents {self.label}: {exc}", file=sys.stderr)
                self.stop_event.wait(self.restart_delay)
                continue

            if self.stop_event.is_set():
                stop_team(proc)
                return

            self.set_proc(proc)
            print(f"GitAgents {self.label} restarted pid={proc.pid}")
            return

    def stop(self):
        self.stop_event.set()
        proc = self.current_proc()
        self.set_proc(None)
        stop_team(proc)
        if self.thread is not None and self.thread.is_alive():
            self.thread.join(timeout=self.check_interval + self.restart_delay + 1)


def main():
    parser = argparse.ArgumentParser(description="GitAgents runner and local web interface")
    parser.add_argument("--root", default=os.environ.get("GIT_AGENTS_STATE_DIR", str(DEFAULT_ROOT)), help="GitAgents state directory")
    parser.add_argument("--host", default=os.environ.get("HOST", "127.0.0.1"), help="Bind host (default: 127.0.0.1)")
    default_port = int(os.environ["PORT"]) if "PORT" in os.environ else DEFAULT_PORT
    parser.add_argument(
        "--port",
        default=default_port,
        type=int,
        help=f"Bind starting port (default: first free port at or above {DEFAULT_PORT})",
    )
    parser.add_argument("--no-team", action="store_true", help=argparse.SUPPRESS)
    parser.add_argument("--no-console", action="store_true", help="do not start the built-in console agent")
    parser.add_argument("--console-model", help="model to pass to the built-in console agent")
    parser.add_argument("--verbose", action="store_true", help="print console transcript output in this terminal")
    parser.add_argument("--registry", action="store_true", help="show all GitAgents instances from the user instances directory")
    parser.add_argument(
        "--registry-dir",
        default=os.environ.get("GIT_AGENTS_REGISTRY_DIR", str(DEFAULT_REGISTRY_DIR)),
        help="GitAgents user instances directory",
    )
    parser.add_argument("team_file", nargs="?", help=argparse.SUPPRESS)
    args = parser.parse_args()

    config = Config(
        root=Path(args.root).expanduser().resolve(),
        host=args.host,
        port=args.port,
        registry=args.registry,
        registry_dir=Path(args.registry_dir).expanduser().resolve(),
    )
    ViewerHandler.config = config

    supervisors = []
    server = bind_server(config)
    if server is None:
        return 1

    def request_stop(_signum, _frame):
        raise KeyboardInterrupt

    signal.signal(signal.SIGTERM, request_stop)

    try:
        if args.team_file:
            print(
                "GitAgents web interface no longer starts team files; use 'git agents start'.",
                file=sys.stderr,
            )
        if not config.registry and not args.no_team and not args.no_console:
            console_supervisor = ProcessSupervisor(
                "console",
                lambda: start_console(config.root, args.console_model, args.verbose),
            )
            console_supervisor.start()
            supervisors.append(console_supervisor)

        print(f"GitAgents running at {server_url(server, config)}")
        if config.registry:
            print(f"Reading GitAgents instances: {config.registry_dir / 'instances'}")
        else:
            print(f"Reading GitAgents root: {config.root}")
        server.serve_forever()
        return 0
    except KeyboardInterrupt:
        print("\nStopping.")
        return 0
    except (RuntimeError, ValueError) as exc:
        print(f"error: {exc}", file=sys.stderr)
        return 1
    finally:
        server.server_close()
        for supervisor in reversed(supervisors):
            supervisor.stop()


if __name__ == "__main__":
    raise SystemExit(main())
