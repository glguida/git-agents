#!/bin/sh
# SPDX-License-Identifier: MIT
set -eu

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
GIT_AGENTS_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
RUN_DIR="$GIT_AGENTS_ROOT/agents/.team-runs"

. "$GIT_AGENTS_ROOT/bin/lib-git-agents"

usage() {
    cat <<'EOF'
Usage: tools/run_git_agents [--verbose] [team-file]

Run the named GitAgents team. Team file format:

  <name> <role> <agent> [model]

If team-file is omitted, git_agents/default.team is used. Blank lines and #
comments are ignored. Agent is one of: pi or pi-interactive.

Options:
  --verbose   Print each agent's rendered transcript output to this terminal.
EOF
}

agent_flag() {
    case "$1" in
        pi) echo "--pi" ;;
        *) die "invalid agent '$1' in team file; expected pi or pi-interactive" ;;
    esac
}

interactive_agent_flag() {
    case "$1" in
        pi-interactive) echo "--pi" ;;
        *) return 1 ;;
    esac
}

run_agent_once() {
    headless_arg="$1"
    agent="$2"
    model="$3"
    role="$4"
    name="$5"

    if interactive_flag="$(interactive_agent_flag "$agent")"; then
        if [ -n "$model" ]; then
            "$SCRIPT_DIR/agent-pi-interactive" $headless_arg "$interactive_flag" -m "$model" "$role" "$name"
        else
            "$SCRIPT_DIR/agent-pi-interactive" $headless_arg "$interactive_flag" "$role" "$name"
        fi
        return
    fi

    flag="$(agent_flag "$agent")"
    if [ -n "$model" ]; then
        "$SCRIPT_DIR/agent" $headless_arg "$flag" -m "$model" "$role" "$name"
    else
        "$SCRIPT_DIR/agent" $headless_arg "$flag" "$role" "$name"
    fi
}

VERBOSE=0

while [ "$#" -gt 0 ]; do
    case "$1" in
        --verbose)
            VERBOSE=1
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        -*)
            usage >&2
            exit 1
            ;;
        *)
            break
            ;;
    esac
done

[ "$#" -le 1 ] || {
    usage >&2
    exit 1
}

TEAM_FILE="${1:-$GIT_AGENTS_ROOT/default.team}"
case "$TEAM_FILE" in
    */*) ;;
    *) TEAM_FILE="$GIT_AGENTS_ROOT/$TEAM_FILE" ;;
esac

[ -f "$TEAM_FILE" ] || die "team file not found: $TEAM_FILE"

mkdir -p "$RUN_DIR"

line_no=0
pids=""

stop_team() {
    echo "stopping GitAgents team" >&2
    for pid in $pids; do
        kill "$pid" 2>/dev/null || true
    done
    wait 2>/dev/null || true
    exit 130
}

trap stop_team INT TERM

while IFS= read -r line || [ -n "$line" ]; do
    line_no=$((line_no + 1))
    case "$line" in
        ""|\#*) continue ;;
    esac

    set -- $line
    [ "$#" -ge 3 ] || die "$TEAM_FILE:$line_no: expected <name> <role> <agent> [model]"
    [ "$#" -le 4 ] || die "$TEAM_FILE:$line_no: too many fields"

    name="$1"
    role="$2"
    agent="$3"
    model="${4:-}"

    validate_agent_id "$name"
    validate_role "$role"
    if ! interactive_agent_flag "$agent" >/dev/null; then
        agent_flag "$agent" >/dev/null
    fi

    (
        while :; do
            headless_arg="--headless"
            [ "$VERBOSE" -eq 1 ] && headless_arg=""
            if run_agent_once "$headless_arg" "$agent" "$model" "$role" "$name"; then
                rc=0
            else
                rc="$?"
            fi
            printf '%s\n' "$rc" > "$RUN_DIR/$name.last-status" 2>/dev/null || true
            printf '%s\n' "$(timestamp)" > "$RUN_DIR/$name.last-exit" 2>/dev/null || true
            sleep 1
        done
    ) &
    pid="$!"
    pids="$pids $pid"
    printf '%s\n' "$pid" > "$RUN_DIR/$name.pid"
    echo "started $name ($role, $agent${model:+, $model}) pid=$pid"
done < "$TEAM_FILE"

[ -n "$pids" ] || die "team file has no agents: $TEAM_FILE"

wait
